    let results = communities.map(c => {
        let r = scoreCommunity(c, inputs);
        return { ...c, ...r };
    }).sort((a, b) => b.score - a.score);

    let html = "<h3>🌿 Top Likely Communities</h3>";

    results.slice(0, 7).forEach(r => {
