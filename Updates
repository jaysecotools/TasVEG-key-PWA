const CACHE = "tasveg-v7.2";

const ASSETS = [
    "./",
    "./index.html",
    "./app.js",
    "./storage.js",
    "./export.js",
    "./manifest.json",
    "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js",
